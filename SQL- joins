****  Syntax 111 Left Outer Join

TYPES: BEGIN OF ty_final,
       matnr    TYPE matnr,
       ernam    TYPE ernam,
       mtart    TYPE mtart,
       mbrsh    TYPE mbrsh,
       werks    TYPE werks,
       END OF   ty_final.

DATA:  it_final  TYPE STANDARD TABLE OF ty_final,
       wa_final  TYPE ty_final,
       lv_matnr TYPE matnr.

SELECT-OPTIONS: so_matnr   FOR lv_matnr.

INITIALIZATION.
  REFRESH : it_final.
  CLEAR   : wa_final.

START-OF-SELECTION.

  IF so_matnr-low IS NOT INITIAL.
    SELECT a~matnr
           a~ernam
           a~mtart
           a~mbrsh
           b~werks
      FROM mara AS a left OUTER JOIN marc AS b
      ON a~matnr EQ b~matnr
      INTO TABLE it_final
      WHERE a~matnr IN so_matnr.

  ELSE.
    MESSAGE i005.
  ENDIF.

  IF it_final IS NOT INITIAL.
    WRITE: /20 'Material Details' COLOR 3.
    SKIP 2.
    WRITE: /20  'Material No.' COLOR 5,
            40  'Person Created' COLOR 5,
            60  'Material Type' COLOR 5,
            75  'Industry Sector' COLOR 5,
            90  'Plant' COLOR 5.
    SKIP.
    LOOP AT it_final INTO wa_final.
      WRITE: /20 wa_final-matnr,
              40 wa_final-ernam,
              60 wa_final-mtart,
              75 wa_final-mbrsh,
              90 wa_final-werks.
    ENDLOOP.
  ELSE.
    MESSAGE i005.
  ENDIF.
