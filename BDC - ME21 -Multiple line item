
REPORT Z_CON_TASK3.

* PURPOSE          : Conversion PO Create. (Call Transaction Method)
* REPORT NAME      : z_con_multi

TYPES: BEGIN OF ty_input,
         id(2)     TYPE c,
         lifnr(10) TYPE c,
         bsart(4)  TYPE c,
         bedat(10) TYPE c,
         ekorg(4)  TYPE  c,
         ekgrp(3)  TYPE c,
         matnr(18) TYPE c,
         menge(12) TYPE c,
         werks(4)  TYPE c,
       END OF ty_input,

       BEGIN OF ty_error,
         id(2)     TYPE c,
         lifnr(10) TYPE c,
         bsart(4)  TYPE c,
         bedat(10) TYPE c,
         ekorg(4)  TYPE  c,
         ekgrp(3)  TYPE c,
         matnr(18) TYPE c,
         menge(12) TYPE c,
         werks(4)  TYPE c,
         desc(220) TYPE c,
       END OF ty_error.

DATA: it_input      TYPE STANDARD TABLE OF ty_input,
      wa_input      TYPE ty_input,
      it_process    TYPE STANDARD TABLE OF ty_input,
      wa_process    TYPE ty_input,
      wa_process1   TYPE ty_input,
      it_error      TYPE STANDARD TABLE OF ty_error,
      wa_error      TYPE ty_error,
      it_bdcdata    TYPE STANDARD TABLE OF bdcdata,
      wa_bdcdata    TYPE bdcdata,
      it_bdcmsgcoll TYPE STANDARD TABLE OF bdcmsgcoll,
      wa_bdcmsgcoll TYPE bdcmsgcoll,
      lv_rdata      TYPE truxs_t_text_data,
      lv_file       TYPE string,
      lv_fpath      TYPE localfile,
      lv_msgid      TYPE bapiret2-id,
      lv_msgno      TYPE bapiret2-number,
      lv_msgv1      TYPE bapiret2-message_v1,
      lv_msgv2      TYPE bapiret2-message_v2,
      lv_msgv3      TYPE bapiret2-message_v3,
      lv_msgv4      TYPE bapiret2-message_v4,
      lv_msg        TYPE bapiret2-message,
      lv_fname      TYPE string,
      lv_fext       TYPE string,
      lv_text       TYPE string,
      lv_succ       TYPE i,
      lv_lines      TYPE i,
      lv_input      TYPE i,
      lv_inputc(10) TYPE c,
      lv_succc(10)  TYPE c,
      lv_errorc(10) TYPE c,
      lv_line(2)    TYPE c,
      lv_flag       TYPE c.

SELECTION-SCREEN BEGIN OF BLOCK b1 WITH FRAME.
PARAMETERS : p_file TYPE localfile.
SELECTION-SCREEN END OF BLOCK b1.

AT SELECTION-SCREEN ON VALUE-REQUEST FOR p_file.
  CALL FUNCTION 'F4_FILENAME'
    EXPORTING
      program_name  = syst-cprog
      dynpro_number = syst-dynnr
      field_name    = 'P_FILE'
    IMPORTING
      file_name     = p_file.

  REFRESH : it_input, it_process, it_error, it_bdcdata, it_bdcmsgcoll.
  CLEAR : wa_input, wa_process, wa_error, wa_bdcdata, wa_bdcmsgcoll,
          lv_rdata, lv_file, lv_fpath, lv_fname, lv_fext,
          lv_lines, lv_flag, lv_line, lv_text.
*include bdcrecx1_s.




START-OF-SELECTION.

  lv_file = p_file.

*validation
  IF lv_file IS NOT INITIAL.
    CALL FUNCTION '/SAPDMC/LSM_PATH_FILE_SPLIT'
      EXPORTING
        pathfile = lv_file
      IMPORTING
        pathname = lv_fpath
        filename = lv_fname.

    SPLIT lv_fname AT '.' INTO lv_fname lv_fext.
    TRANSLATE lv_fext TO UPPER CASE.
    IF lv_fext = 'XLS' OR lv_fext = 'XLSX'.
      CALL FUNCTION 'TEXT_CONVERT_XLS_TO_SAP'
        EXPORTING
          i_field_seperator    = 'X'
          i_line_header        = 'X'
          i_tab_raw_data       = lv_rdata
          i_filename           = p_file
        TABLES
          i_tab_converted_data = it_input
        EXCEPTIONS
          conversion_failed    = 1
          OTHERS               = 2.
      IF sy-subrc <> 0.
        lv_flag = abap_true.
        MESSAGE 'Error in Input File' TYPE 'I'.
      ELSE.
        DESCRIBE TABLE it_input LINES lv_lines.
        IF lv_lines GT 0.
          lv_input = lv_lines.
        ELSE.
          lv_flag = abap_true.
          MESSAGE 'No Records in Input File' TYPE 'I'.
        ENDIF.
      ENDIF.
    ELSE.
      lv_flag = abap_true.
      MESSAGE 'Select XLS or XLSX' TYPE 'I'.
    ENDIF.
  ELSE.
    lv_flag = abap_true.
    MESSAGE 'Plese Select the file' TYPE 'I'.
  ENDIF.

*if validation success
  IF lv_flag = abap_false.
    "file content validation
    LOOP AT it_input INTO wa_input.
      CLEAR: wa_process, wa_error.
      IF wa_input-lifnr IS NOT INITIAL AND wa_input-bedat IS NOT INITIAL AND
        wa_input-bsart IS NOT INITIAL AND wa_input-ekorg IS NOT INITIAL AND
        wa_input-ekgrp IS NOT INITIAL AND wa_input-matnr IS NOT INITIAL AND
        wa_input-menge IS NOT INITIAL AND wa_input-werks IS NOT INITIAL.
        MOVE-CORRESPONDING wa_input TO wa_process.
        APPEND wa_process TO it_process.
      ELSE.
        MOVE-CORRESPONDING wa_input TO wa_error.
        wa_error-desc = 'Please Fill the data'.
        APPEND wa_error TO it_error.
      ENDIF.
    ENDLOOP.

    IF it_process IS NOT INITIAL.
      LOOP AT it_process INTO wa_process1.
        lv_line = lv_line + 1.
        CLEAR wa_process.
        MOVE-CORRESPONDING wa_process1 TO wa_process.
      at NEW id.


      PERFORM bdc_dynpro      USING 'SAPMM06E' '0100'.
      PERFORM bdc_field       USING 'BDC_CURSOR' 'EKKO-LIFNR'.
      PERFORM bdc_field       USING 'BDC_OKCODE' '/00'.
      PERFORM bdc_field       USING 'EKKO-LIFNR'   wa_process-lifnr.
      PERFORM bdc_field       USING 'RM06E-BSART'  wa_process-bsart.
      PERFORM bdc_field       USING 'RM06E-BEDAT'  wa_process-bedat.
      PERFORM bdc_field       USING 'EKKO-EKORG'   wa_process-ekorg.
      PERFORM bdc_field       USING 'EKKO-EKGRP'   wa_process-ekgrp.
      PERFORM bdc_field       USING 'RM06E-LPEIN'  'T'.
      ENDAT.

      PERFORM bdc_dynpro      USING 'SAPMM06E' '0120'.
      PERFORM bdc_field       USING 'BDC_CURSOR' 'EKPO-WERKS(01)'.
      PERFORM bdc_field       USING 'BDC_OKCODE' '/00'.
      CLEAR lv_text.
      CONCATENATE 'EKPO-EMATN(0' lv_line ')' INTO lv_text.
      PERFORM bdc_field       USING lv_text wa_process-matnr.
      clear lv_text.
      CONCATENATE 'EKPO-MENGE(0' lv_line ')' INTO lv_text.
      PERFORM bdc_field       USING lv_text wa_process-menge.
      clear lv_text.
      CONCATENATE 'EKPO-WERKS(0' lv_line ')' INTO lv_text.
      PERFORM bdc_field       USING lv_text wa_process-werks.


      AT END OF id.
      PERFORM bdc_dynpro      USING 'SAPMM06E' '0120'.
      PERFORM bdc_field       USING 'BDC_CURSOR' lv_line.
      PERFORM bdc_field       USING 'BDC_OKCODE' '=BU'.
*      PERFORM bdc_field       USING 'RM06E-EBELP'  .

        CALL TRANSACTION 'ME21'
                USING it_bdcdata
                      MODE 'N' "A/E/N
                      UPDATE 'S' "A/S
                 MESSAGES INTO it_bdcmsgcoll.
        READ TABLE it_bdcmsgcoll INTO wa_bdcmsgcoll WITH KEY msgtyp ='E'.
        IF sy-subrc EQ 0.
          CLEAR: lv_msgid, lv_msgno, lv_msgv1,lv_msgv2,lv_msgv3,lv_msgv4,lv_msg.
          lv_msgid = wa_bdcmsgcoll-msgid.
          lv_msgno = wa_bdcmsgcoll-msgnr.
          lv_msgv1 = wa_bdcmsgcoll-msgv1.
          lv_msgv2 = wa_bdcmsgcoll-msgv2.
          lv_msgv3 = wa_bdcmsgcoll-msgv3.
          lv_msgv4 = wa_bdcmsgcoll-msgv4.

          CALL FUNCTION 'BAPI_MESSAGE_GETDETAIL'
            EXPORTING
              id         = lv_msgid
              number     = lv_msgno
              textformat = 'ASC'
              message_v1 = lv_msgv1
              message_v2 = lv_msgv2
              message_v3 = lv_msgv3
              message_v4 = lv_msgv4
            IMPORTING
              message    = lv_msg.
          LOOP AT it_input INTO wa_input WHERE id = wa_process-id.
          CLEAR wa_error.
          MOVE-CORRESPONDING wa_process TO wa_error.
          wa_error-desc = lv_msg.
          APPEND wa_error TO it_error.
          ENDLOOP.
          lv_lines = lv_lines + 1.
        ELSE.
          lv_succ = lv_succ + 1.
        ENDIF.
                REFRESH : it_bdcdata, it_bdcmsgcoll.
                CLEAR lv_line.
        ENDAT.
      ENDLOOP.

      IF it_error IS NOT INITIAL.
        CONCATENATE lv_fpath 'Error' INTO lv_fpath.
        CONCATENATE lv_fpath sy-datum sy-uzeit INTO lv_fpath SEPARATED BY '_'.
        TRANSLATE lv_fext TO LOWER CASE.
        CONCATENATE lv_fpath lv_fext INTO lv_fpath SEPARATED BY '.'.

        CLEAR wa_error.
        wa_error-id = 'ID'.
        wa_error-lifnr = 'LIFNR'.
        wa_error-bsart = 'BSART'.
        wa_error-bedat = 'EKORG'.
        wa_error-ekorg = 'EKGRP'.
        wa_error-matnr = 'MATNR'.
        wa_error-menge = 'MENGE'.
        wa_error-werks = 'WERKS'.
        wa_error-desc = 'Description'.
        INSERT wa_error INTO it_error INDEX 1.

        CALL FUNCTION 'SAP_CONVERT_TO_XLS_FORMAT'
          EXPORTING
            i_field_seperator = 'X'
            i_filename        = lv_fpath
          TABLES
            i_tab_sap_data    = it_error
          EXCEPTIONS
            conversion_failed = 1
            OTHERS            = 2.
        IF sy-subrc <> 0.
          MESSAGE 'Error in File Download' TYPE 'S'.
        ELSE.
          MESSAGE 'Error File Downloaded' TYPE 'S'.
        ENDIF.
      ENDIF.

      CLEAR lv_lines.
      lv_lines = lv_input - lv_succ.
      lv_inputc = lv_input.
      lv_succc = lv_succ.
      lv_errorc = lv_lines.
      CONDENSE : lv_inputc, lv_succc, lv_errorc.

      WRITE: /20 'Program to Purchase Order' COLOR 5.
      SKIP 2.
      WRITE : / 'No. of Records Updated Success : ',lv_succc,
              / 'No. of error records           : ',lv_errorc.
      IF lv_lines GT 0.
        WRITE : / 'Error file Downloaded Location : ',lv_fpath.
      ENDIF.

    ENDIF. "Process Table Filled
  ENDIF. "Flag validation



*----------------------------------------------------------------------*
*        Start new screen                                              *
*----------------------------------------------------------------------*
FORM bdc_dynpro USING program dynpro.
  CLEAR wa_bdcdata.
  wa_bdcdata-program  = program.
  wa_bdcdata-dynpro   = dynpro.
  wa_bdcdata-dynbegin = 'X'.
  APPEND wa_bdcdata to it_bdcdata.
ENDFORM.

*----------------------------------------------------------------------*
*        Insert field                                                  *
*----------------------------------------------------------------------*
FORM bdc_field USING fnam fval.
    CLEAR wa_bdcdata.
    wa_bdcdata-fnam = fnam.
    wa_bdcdata-fval = fval.
    APPEND wa_bdcdata to it_bdcdata.
ENDFORM.
